    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Hardware features -->
    <uses-feature android:name="android.hardware.sensor.compass"       android:required="false" />
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />
    <uses-feature android:name="android.hardware.sensor.gyroscope"     android:required="false" />
    <uses-feature android:name="android.hardware.camera.flash"         android:required="false" />
    <uses-feature android:name="android.hardware.sensor.proximity"     android:required="false" />
    <uses-feature android:name="android.hardware.telephony"            android:required="false" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         HAIL PERMISSIONS
    ════════════════════════════════════════════════════════════════════════ -->
    <uses-sdk tools:overrideLibrary="rikka.shizuku.api, com.rosan.dhizuku.api"/>
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"/>
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES"/>
    <uses-permission android:name="android.permission.FORCE_STOP_PACKAGES"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.CHANGE_COMPONENT_ENABLED_STATE"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.MANAGE_APP_OPS_MODES"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="com.oasisfeng.island.permission.FREEZE_PACKAGE"/>
    <uses-permission android:name="com.oasisfeng.island.permission.SUSPEND_PACKAGE"/>

    <!-- ═══════════════════════════════════════════════════════════════════════
         LOCKSCREEN WIDGETS PERMISSIONS
    ════════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD" />
    <uses-permission android:name="android.permission.BIND_APPWIDGET"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.ACCESS_HIDDEN_PROFILES" />
    <uses-permission android:name="tk.zwander.lockscreenwidgets.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <!-- Huawei weather (used by some LSW widgets) -->
    <uses-permission android:name="com.huawei.android.totemweather.permission.ACCESS_WEATHERCLOCK_PROVIDER" />
    <uses-permission android:name="android.permission.ACCESS_WEATHERCLOCK_PROVIDER" />

    <application
        android:name=".EverlastingApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EverlastingAndroidTweak"
        tools:targetApi="31">

        <!-- ══════════════════════════════════════════════════════════════════
             EVERLASTING ACTIVITIES
        ═══════════════════════════════════════════════════════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.EverlastingAndroidTweak">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SwiftSlate -->
        <activity
            android:name="com.musheer360.swiftslate.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.EverlastingAndroidTweak" />

        <!-- Watermark -->
        <activity
            android:name=".ui.activities.WatermarkActivity"
            android:exported="false"
            android:theme="@style/Theme.EverlastingAndroidTweak"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
        </activity>

        <!-- ══════════════════════════════════════════════════════════════════
             EVERLASTING SERVICES
        ═══════════════════════════════════════════════════════════════════ -->
        <!-- Single merged accessibility service: Everlasting + Lock Screen Widgets + SwiftSlate AI -->
        <service
            android:name=".services.EverlastingAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            tools:ignore="AccessibilityPolicy">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>


        <service android:name=".services.EverlastingForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />
        <service android:name=".features.musicleveler.MusicLevelerOverlayService"
            android:exported="false" />
        <service android:name=".features.navbar.NavBarOverlayService"
            android:exported="false" />
        <service android:name=".features.screensaver.ScreensaverService"
            android:exported="true"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.service.dream"
                android:resource="@xml/screensaver_config" />
        </service>

        <!-- QS Tiles -->
        <service android:name=".features.tiles.UiBlurTileService" android:exported="true"
            android:label="@string/tile_ui_blur" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.MonoAudioTileService" android:exported="true"
            android:label="@string/tile_mono_audio" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.SoundModeTileService" android:exported="true"
            android:label="@string/tile_sound_mode" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.StayAwakeTileService" android:exported="true"
            android:label="@string/tile_stay_awake" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.AdaptiveBrightnessTileService" android:exported="true"
            android:label="@string/tile_adaptive_brightness" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.NfcTileService" android:exported="true"
            android:label="@string/tile_nfc" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.AodTileService" android:exported="true"
            android:label="@string/tile_aod" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.TapToWakeTileService" android:exported="true"
            android:label="@string/tile_tap_to_wake" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.SensitiveLockTileService" android:exported="true"
            android:label="@string/tile_sensitive_lock" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.PrivateDnsTileService" android:exported="true"
            android:label="@string/tile_private_dns" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.UsbDebuggingTileService" android:exported="true"
            android:label="@string/tile_usb_debugging" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.DevOptionsTileService" android:exported="true"
            android:label="@string/tile_dev_options" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.CaffeinateTileService" android:exported="true"
            android:label="@string/tile_caffeinate" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.FlipDndTileService" android:exported="true"
            android:label="@string/tile_flip_dnd" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>
        <service android:name=".features.tiles.VolumeBoostTileService" android:exported="true"
            android:label="@string/tile_volume_boost" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>

        <service android:name=".features.tiles.ScaleAnimationsTileService" android:exported="true"
            android:label="@string/tile_scale_animations" android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter></service>

        <!-- ══════════════════════════════════════════════════════════════════
             EVERLASTING RECEIVERS / PROVIDERS
        ═══════════════════════════════════════════════════════════════════ -->
        <receiver android:name=".services.BootReceiver" android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        <receiver android:name=".features.autoreboot.AutoRebootReceiver" android:exported="false" />

        <!-- Notification Lighting + Flash Pulse -->
        <service
            android:name=".features.notiflight.NotificationLightingService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />
        <receiver
            android:name=".features.notiflight.FlashlightActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.coolappstore.everlastingandroidtweak.ACTION_PULSE_NOTIFICATION" />
                <action android:name="com.coolappstore.everlastingandroidtweak.ACTION_FLASHLIGHT_TOGGLE" />
            </intent-filter>
        </receiver>
        <receiver android:name=".features.watermark.WatermarkReceiver" android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_SCANNER_SCAN_FILE" />
                <data android:scheme="file" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Shizuku (one provider covers both Everlasting + LSW) -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!-- ══════════════════════════════════════════════════════════════════
             HAIL APP FREEZER INTEGRATION
        ═══════════════════════════════════════════════════════════════════ -->
        <activity
            android:name="com.aistra.hail.ui.main.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Hail">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE_PREFERENCES"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
        <activity
            android:name="com.aistra.hail.ui.api.ApiActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="singleInstance"
            android:theme="@style/Theme.Hail.Translucent">
            <intent-filter>
                <action android:name="android.intent.action.SHOW_APP_INFO"/>
                <action android:name="com.aistra.hail.action.LAUNCH"/>
                <action android:name="com.aistra.hail.action.FREEZE"/>
                <action android:name="com.aistra.hail.action.UNFREEZE"/>
                <action android:name="com.aistra.hail.action.FREEZE_TAG"/>
                <action android:name="com.aistra.hail.action.UNFREEZE_TAG"/>
                <action android:name="com.aistra.hail.action.FREEZE_ALL"/>
                <action android:name="com.aistra.hail.action.UNFREEZE_ALL"/>
                <action android:name="com.aistra.hail.action.FREEZE_NON_WHITELISTED"/>
                <action android:name="com.aistra.hail.action.FREEZE_AUTO"/>
                <action android:name="com.aistra.hail.action.LOCK"/>
                <action android:name="com.aistra.hail.action.LOCK_FREEZE"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="hail"/>
            </intent-filter>
        </activity>
        <receiver android:name="com.aistra.hail.receiver.DeviceAdminReceiver"
            android:description="@string/action_lock"
            android:exported="false"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data android:name="android.app.device_admin" android:resource="@xml/device_admin"/>
            <intent-filter><action android:name="android.app.action.DEVICE_ADMIN_ENABLED"/></intent-filter>
        </receiver>
        <receiver android:name=".features.security.SecurityDeviceAdminReceiver"
            android:description="@string/app_name"
            android:exported="false"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data android:name="android.app.device_admin" android:resource="@xml/device_admin"/>
            <intent-filter><action android:name="android.app.action.DEVICE_ADMIN_ENABLED"/></intent-filter>
        </receiver>
        <receiver android:name="com.aistra.hail.receiver.ScreenOffReceiver" android:exported="false"/>
        <receiver android:name="com.aistra.hail.receiver.UnsuspendedReceiver" android:exported="false">
            <intent-filter><action android:name="android.intent.action.PACKAGE_UNSUSPENDED_MANUALLY"/></intent-filter>
        </receiver>
        <service android:name="com.aistra.hail.services.QSTileService" android:exported="true"
            android:icon="@drawable/ic_round_frozen" android:label="@string/tile_action"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter><action android:name="android.service.quicksettings.action.QS_TILE"/></intent-filter>
        </service>
        <service android:name="com.aistra.hail.services.AutoFreezeService"
            android:foregroundServiceType="specialUse" android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
        </service>

        <!-- ══════════════════════════════════════════════════════════════════
             LOCKSCREEN WIDGETS INTEGRATION
        ═══════════════════════════════════════════════════════════════════ -->

