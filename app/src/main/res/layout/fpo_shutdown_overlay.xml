<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Initial Shutdown View -->
    <RelativeLayout
        android:id="@+id/fpo_shutdown_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center">

        <ProgressBar
            android:id="@+id/fpo_spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:layout_centerInParent="false"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="45dp"
            android:indeterminateTint="@android:color/white"
            android:padding="15dp" />

        <TextView
            android:id="@+id/fpo_shutdown_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/fpo_spinner"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp"
            android:text="Shutting down\u2026"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            tools:ignore="HardcodedText"
            xmlns:tools="http://schemas.android.com/tools"/>
    </RelativeLayout>

    <!-- Dismiss-sequence input indicator (hidden by default) -->
    <TextView
        android:id="@+id/fpo_countdown_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@android:color/white"
        android:textSize="48sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/fpo_input_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:letterSpacing="0.2"
        android:textColor="#80FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:visibility="gone" />

</FrameLayout>
