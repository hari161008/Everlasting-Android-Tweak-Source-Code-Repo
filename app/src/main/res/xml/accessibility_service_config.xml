<?xml version="1.0" encoding="utf-8"?>
<!--
    Merged accessibility config for EverlastingAccessibilityService.
    Covers:
      - Everlasting: haptics, sounds, key events, SwiftSlate AI
      - LSW: lock screen widgets overlay, window/keyguard detection
      - SwiftSlate: AI text replacement (merged into Everlasting)
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeViewClicked|typeViewScrolled|typeWindowStateChanged|typeViewTextChanged|typeWindowsChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds|flagRequestFilterKeyEvents|flagDefault|flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:canRequestFilterKeyEvents="true"
    android:canPerformGestures="false"
    android:description="@string/accessibility_service_label"
    android:notificationTimeout="50"
    android:settingsActivity=".MainActivity" />
